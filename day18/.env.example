# Хост погодного MCP-сервера
MCP_WEATHER_HOST=localhost

# Порт погодного MCP-сервера
MCP_WEATHER_PORT=9001

# Ключ аутентификации погодного сервера (опционально)
MCP_AUTH_KEY=

# Порт для запуска weather_scheduler
MCP_SCHEDULER_PORT=9002

# Период хранения данных (часов)
DATA_RETENTION_HOURS=24

# Таймаут запросов к погодному серверу (секунд)
WEATHER_CLIENT_TIMEOUT=30
