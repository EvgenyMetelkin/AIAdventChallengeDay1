# API Configuration
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=gpt-3.5-turbo

# Agent Configuration
TEMPERATURE=0.7
MAX_TOKENS=500
VERBOSE=False
AGENT_ID=1

# Storage
HISTORY_DIR=agent_history
FILES_DIR=agent_files
MAX_FILE_SIZE_MB=10

# Context Management
KEEP_LAST_N_MESSAGES=10
SUMMARY_INTERVAL=10

# Allowed file extensions
ALLOWED_EXTENSIONS=txt,md,py,json,yaml,yml,toml,ini,cfg,conf,log,csv,tsv,xml,html,htm,css,js,jsx,ts,tsx,rst,tex,sh,bat,ps1,sql,r,jl,go,rs,swift,kt,java,c,cpp,h,hpp,cs,php,rb,pl,lua,scala,clj,cljs,groovy,gradle,dockerfile,makefile